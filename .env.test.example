# Copy this file to .env.test and fill in real test-user credentials.
# .env.test is gitignored — never commit real credentials.

# A Supabase user that exists in your dev project.
# Use a dedicated test account, not your personal login.
E2E_TEST_EMAIL=testuser@example.com
E2E_TEST_PASSWORD=your-test-password

# Override the base URL if your dev server runs on a different port.
# E2E_BASE_URL=http://localhost:3000
